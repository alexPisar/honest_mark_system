<Window x:Class="OmsQrCodesMakerApp.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:control="clr-namespace:FilterDataGrid;assembly=FilterDataGrid"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:SearchableComboBox="clr-namespace:SearchableComboBox;assembly=SearchableComboBox"
        xmlns:local="clr-namespace:OmsQrCodesMakerApp"
        mc:Ignorable="d" ResizeMode="NoResize"
        Title="Вход" Height="220" Width="400" Background="Yellow">
    <Grid>
        <StackPanel Orientation="Vertical" Margin="5">
            <StackPanel Orientation="Horizontal">
                <Label Margin="10" Content="Данные для входа на станцию управления заказами" />
                <Image Margin="15 5" Source="pack://siteoforigin:,,,/Resources/HonestMark.png" Height="40" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0 5">
                <Label Content="Сертификат" Width="90" />
                <SearchableComboBox:DataGridComboBox Margin="10 0" Width="250"
                                                     ItemsSource="{Binding Certificates, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                     SelectedItem="{Binding SelectedCertificate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     SelectedItemChanged="DataGridComboBox_SelectedItemChanged"
                                                     DisplayMemberPath="SubjectName" IsSearchEnabled="True">
                    <SearchableComboBox:DataGridComboBox.Columns>
                        <control:DataGridTextColumn Header="Субьект" Width="150" Binding ="{Binding Path=SubjectName, Mode=OneWay}" IsColumnFiltered="True">
                            <control:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap" />
                                </Style>
                            </control:DataGridTextColumn.ElementStyle>
                        </control:DataGridTextColumn>
                        <control:DataGridTextColumn Header="ИНН" Width="120" IsColumnFiltered="True" Binding="{Binding Path=Inn, Mode=OneWay}"/>
                        <control:DataGridTextColumn Header="Отпечаток" Width="280" IsColumnFiltered="True" Binding="{Binding Path=Thumbprint, Mode=OneWay}"/>
                    </SearchableComboBox:DataGridComboBox.Columns>
                </SearchableComboBox:DataGridComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0 5">
                <Label Content="Организация" Width="90" />
                <SearchableComboBox:DataGridComboBox Margin="10 0" Width="250"
                                                     AllItemsSource="{Binding Organizations, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                     SelectedItem="{Binding SelectedOrganization, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     DisplayMemberPath = "Name" IsSearchEnabled="True">
                    <SearchableComboBox:DataGridComboBox.Columns>
                        <control:DataGridTextColumn Header="Наименование" IsColumnFiltered="True" Width="150" Binding="{Binding Path=Name, Mode=OneWay}"/>
                        <control:DataGridTextColumn Header="ИНН" IsColumnFiltered="True" Width="110" Binding="{Binding Path=Inn, Mode=OneWay}"/>
                    </SearchableComboBox:DataGridComboBox.Columns>
                </SearchableComboBox:DataGridComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 5">
                <Button x:Name="LoginButton" Background="LightGray" Margin="5 0" Width="80" Height="25" Content="Вход" Click="LoginButton_Click" />
                <Button x:Name="CancelButton" Background="LightGray" Margin="5 0" Width="80" Height="25" Content="Отмена" Click="CancelButton_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>

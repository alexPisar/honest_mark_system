<r:RibbonWindow
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
        xmlns:control="clr-namespace:FilterDataGrid;assembly=FilterDataGrid"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:r="clr-namespace:System.Windows.Controls.Ribbon;assembly=System.Windows.Controls.Ribbon"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OmsQrCodesMakerApp"
        x:Class="OmsQrCodesMakerApp.OrderSingleWindow"
        mc:Ignorable="d"
        Title="Состав заказа" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <r:Ribbon>
            <r:Ribbon.ApplicationMenu>
                <r:RibbonApplicationMenu Visibility="Collapsed"></r:RibbonApplicationMenu>
            </r:Ribbon.ApplicationMenu>
            <r:RibbonTab Header="Товары">
                <r:RibbonGroup>
                    <r:RibbonButton LargeImageSource="{svg:SvgImage Source=SvgImage/Action_Refresh.svg}"
                                    Label="Обновить" Command="{Binding RefreshCommand}" />
                    <r:RibbonButton LargeImageSource="{svg:SvgImage Source=SvgImage/BO_List.svg}"
                                    Label="Выпустить коды" Command="{Binding ReleaseCodesCommand}"/>
                    <r:RibbonButton LargeImageSource="{svg:SvgImage Source=SvgImage/CheckBox.svg}"
                                    Label="Получить коды повторно" Command="{Binding RetryGetCodesCommand}"/>
                </r:RibbonGroup>
            </r:RibbonTab>
        </r:Ribbon>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="35" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBox Grid.Row="0" Margin="5 0" Height="25" Width="150" HorizontalAlignment="Right" VerticalAlignment="Center" VerticalContentAlignment="Center" Text="{Binding Search, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <control:FilterDataGrid Grid.Row="1" ItemsSource="{Binding ItemsList, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SelectedItem="{Binding SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource FilterDatagridStyle}">
                <control:FilterDataGrid.Columns>
                    <control:DataGridTextColumn Header="Штрих код" IsColumnFiltered="True" Binding="{Binding Path=Gtin, Mode=OneWay}" Width="120" />
                    <control:DataGridTextColumn Header="Наименование" IsColumnFiltered="True" Binding="{Binding Path=Product.Name, Mode=OneWay}" Width="120" />
                    <control:DataGridTextColumn Header="Брэнд" IsColumnFiltered="True" Binding="{Binding Path=Product.Brand, Mode=OneWay}" Width="80" />
                    <control:DataGridNumericColumn Header="Заказанные коды" Binding="{Binding Path=OrderStatus.TotalCodes, Mode=OneWay}" Width="120" />
                    <control:DataGridNumericColumn Header="Полученные коды" Binding="{Binding Path=OrderStatus.TotalPassed, Mode=OneWay}" Width="120"/>
                    <control:DataGridNumericColumn Header="Оставшиеся коды" Binding="{Binding Path=OrderStatus.LeftInBuffer, Mode=OneWay}" Width="120"/>
                    <control:DataGridTextColumn Header="Статус буфера" IsColumnFiltered="True" Binding="{Binding Path=BufferStatus, Mode=OneWay}" Width="120"/>
                </control:FilterDataGrid.Columns>
            </control:FilterDataGrid>
        </Grid>
    </Grid>
</r:RibbonWindow>
